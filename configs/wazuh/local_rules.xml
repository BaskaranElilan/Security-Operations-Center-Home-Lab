<!--
  Custom Wazuh Rules for SOC Home Lab
  
  Location: /var/ossec/etc/rules/local_rules.xml (Wazuh Server)
  
  These rules trigger alerts when Suricata NIDS detects network
  threats, enabling correlation between network and endpoint events.
-->

<group name="local,suricata,ids,">

  <!-- ==================== Suricata Alert Rules ==================== -->

  <!-- Base rule: Any Suricata alert detected -->
  <rule id="100100" level="3">
    <decoded_as>suricata</decoded_as>
    <field name="event_type">^alert$</field>
    <description>Suricata: Network alert detected — $(alert.signature)</description>
    <group>suricata,network,ids,</group>
  </rule>

  <!-- Suricata: Low severity alert (severity 3) -->
  <rule id="100101" level="5">
    <if_sid>100100</if_sid>
    <field name="alert.severity">3</field>
    <description>Suricata: Low severity network alert — $(alert.signature)</description>
    <group>suricata,network,ids,low,</group>
  </rule>

  <!-- Suricata: Medium severity alert (severity 2) -->
  <rule id="100102" level="8">
    <if_sid>100100</if_sid>
    <field name="alert.severity">2</field>
    <description>Suricata: Medium severity network alert — $(alert.signature)</description>
    <group>suricata,network,ids,medium,</group>
  </rule>

  <!-- Suricata: High severity alert (severity 1) -->
  <rule id="100103" level="12">
    <if_sid>100100</if_sid>
    <field name="alert.severity">1</field>
    <description>Suricata: HIGH severity network alert — $(alert.signature)</description>
    <group>suricata,network,ids,high,</group>
  </rule>

  <!-- ==================== Port Scan Detection ==================== -->

  <!-- Suricata: Port scan detected -->
  <rule id="100110" level="8">
    <if_sid>100100</if_sid>
    <field name="alert.category">Attempted Information Leak</field>
    <description>Suricata: Possible port scan detected from $(src_ip) — $(alert.signature)</description>
    <group>suricata,network,ids,recon,scan,</group>
  </rule>

  <!-- ==================== Exploit Detection ==================== -->

  <!-- Suricata: Exploit attempt detected -->
  <rule id="100120" level="12">
    <if_sid>100100</if_sid>
    <field name="alert.category">Attempted Administrator Privilege Gain</field>
    <description>Suricata: EXPLOIT attempt from $(src_ip) to $(dest_ip) — $(alert.signature)</description>
    <group>suricata,network,ids,exploit,</group>
  </rule>

  <!-- Suricata: Web attack detected -->
  <rule id="100121" level="10">
    <if_sid>100100</if_sid>
    <field name="alert.category">Web Application Attack</field>
    <description>Suricata: Web application attack from $(src_ip) — $(alert.signature)</description>
    <group>suricata,network,ids,web_attack,</group>
  </rule>

  <!-- ==================== Malware Detection ==================== -->

  <!-- Suricata: Malware activity detected -->
  <rule id="100130" level="14">
    <if_sid>100100</if_sid>
    <field name="alert.category">A Network Trojan was detected</field>
    <description>Suricata: MALWARE network activity from $(src_ip) — $(alert.signature)</description>
    <group>suricata,network,ids,malware,</group>
  </rule>

  <!-- ==================== SSH Brute Force (Endpoint) ==================== -->

  <!-- Multiple SSH authentication failures -->
  <rule id="100200" level="10" frequency="5" timeframe="120">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SOC Lab: SSH brute force attack detected from $(srcip) (5+ failures in 2 min)</description>
    <group>authentication_failures,ssh,brute_force,</group>
  </rule>

  <!-- ==================== File Integrity ==================== -->

  <!-- Critical system file modified -->
  <rule id="100300" level="12">
    <if_sid>550</if_sid>
    <match>/etc/passwd|/etc/shadow|/etc/sudoers</match>
    <description>SOC Lab: CRITICAL system file modified — $(file)</description>
    <group>syscheck,file_integrity,critical,</group>
  </rule>

</group>
